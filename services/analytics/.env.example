# Required for local npm commands (db:push, start). From this folder run:
#   copy .env.example .env
#
# Match DB_PASSWORD and the DEMO_* ids with roognis/.env at the repo root.
#
# Postgres must be running before db:push. From roognis/ start only Postgres:
#   docker compose up postgres -d
# Or run the full stack (recommended):
#   docker compose up --build analytics
# Inside Docker, DATABASE_URL is injected automatically — no .env needed there.

DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/roognis?schema=analytics_db
INTERNAL_SERVICE_TOKEN=roognis-internal-token-change-me
PORT=3004

# Auth removed — no JWT_SECRET. These fixed ids stand in for the caller identity
# that the JWT used to supply, and must match services/ai and services/rag.
DEMO_SCHOOL_ID=00000000-0000-0000-0000-000000000001
DEMO_STUDENT_ID=00000000-0000-0000-0000-000000000002
DEMO_TEACHER_ID=00000000-0000-0000-0000-000000000003
