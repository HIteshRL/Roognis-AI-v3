# ─────────────────────────────────────────────────────────────────────────────
# Roognis AI — Environment Configuration
# Copy this file to .env and fill in values before running docker-compose up
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth removed ─────────────────────────────────────────────────────────────
# The auth service has been deleted and no service verifies a JWT, so there is
# no JWT_SECRET, no login, and no roles. Every API endpoint is open.
#
# With nothing to identify the caller, the services fall back to a single fixed
# demo tenant. These ids are shared by ai, analytics, and rag — change them
# together or the analytics roster won't match the events the ai service emits.
DEMO_SCHOOL_ID=00000000-0000-0000-0000-000000000001
DEMO_STUDENT_ID=00000000-0000-0000-0000-000000000002
DEMO_TEACHER_ID=00000000-0000-0000-0000-000000000003

# ── Core secrets (required) ──────────────────────────────────────────────────
# PostgreSQL password
DB_PASSWORD=postgres123

# Shared internal token for service-to-service analytics event ingestion.
# This is service-to-service only — it is NOT user auth and still applies.
# Generate: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=roognis-internal-token-change-me

# ── AI providers for MVP ─────────────────────────────────────────────────────
# Gemini keeps the demo lightweight: no local Ollama model or ComfyUI image model download.
LLM_PROVIDER=gemini
IMAGE_PROVIDER=gemini
GEMINI_API_KEY=

# Set these to the exact Gemini models enabled for your key.
# Keep the defaults if they are available in your AI Studio project.
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Real-time video search. Add a YouTube Data API key to fetch live video results.
VIDEO_PROVIDER=youtube
YOUTUBE_API_KEY=
VIDEO_SEARCH_MAX_RESULTS=5
# Optional comma-separated channel title filter, for example:
# VIDEO_TRUSTED_CHANNELS=Khan Academy,Amoeba Sisters,CrashCourse,Crash Course Kids
VIDEO_TRUSTED_CHANNELS=

# Local fallback:
# LLM_PROVIDER=ollama
# IMAGE_PROVIDER=comfyui
# docker-compose --profile local-ai up --build

# RAG / EKE ingestion
# Fast MVP default uses lexical retrieval and deterministic local embeddings.
# For full Chroma/Ollama vector retrieval, set RAG_TEST_MODE=false and run:
# docker-compose --profile local-ai up --build
RAG_TEST_MODE=true
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
RAG_COLLECTION_PREFIX=school
RAG_MAX_UPLOAD_MB=50

# ── Cloud swap knobs ──────────────────────────────────────────────────────────

# Swap ChromaDB → Pinecone
# PINECONE_API_KEY=
# PINECONE_ENV=

# Swap Docker volume → AWS S3
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
